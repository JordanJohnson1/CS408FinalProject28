<% if current_player.nil? %>
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card border-0 card-shadow">
        <div class="card-body p-4">
          <h2 class="fw-bold mb-2">Create your skater</h2>
          <p class="text-muted mb-3">Start a run by registering a player.</p>
          <%= render "players/form" %>
        </div>
      </div>
    </div>
  </div>
<% else %>
  <div class="d-flex flex-column gap-4" data-controller="run-session trick-input skate-canvas"
       data-run-session-create-url-value="<%= runs_path %>"
       data-run-session-run-tricks-url-value="<%= run_tricks_path %>"
       data-run-session-player-value="<%= current_player.as_json(only: [:id, :name, :coins, :xp, :best_combo, :total_tricks]).to_json %>"
       data-run-session-tricks-value='<%= @tricks.map { |t| { id: t.id, name: t.name, input: t.input_sequence, baseCoins: t.base_coins, baseXp: t.base_xp, difficulty: t.difficulty } }.to_json %>'
       data-trick-input-tricks-value='<%= @tricks.map { |t| { id: t.id, name: t.name, input: t.input_sequence } }.to_json %>'>
    <div class="card border-0 card-shadow">
      <div class="card-body p-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
          <div>
            <p class="eyebrow text-uppercase mb-2">Active player</p>
            <h2 class="fw-bold mb-1" data-run-session-target="playerName"><%= current_player.name %></h2>
            <p class="text-muted mb-0">Press space + arrows for tricks. Watch coins rack up live.</p>
          </div>
          <div class="text-end">
            <p class="text-muted small mb-1">Run status</p>
            <div class="fs-5 fw-bold" data-run-session-target="status">Waiting</div>
          </div>
        </div>
        <div class="row g-3">
          <div class="col-md-3">
            <div class="stat-tile">
              <span class="stat-label">Coins</span>
              <span class="stat-value" data-run-session-target="coins"><%= current_player.coins %></span>
            </div>
          </div>
          <div class="col-md-3">
            <div class="stat-tile">
              <span class="stat-label">XP</span>
              <span class="stat-value" data-run-session-target="xp"><%= current_player.xp %></span>
            </div>
          </div>
          <div class="col-md-3">
            <div class="stat-tile">
              <span class="stat-label">Best combo</span>
              <span class="stat-value" data-run-session-target="bestCombo"><%= current_player.best_combo %></span>
            </div>
          </div>
          <div class="col-md-3">
            <div class="stat-tile">
              <span class="stat-label">Run time</span>
              <span class="stat-value" data-run-session-target="runClock">00:00</span>
            </div>
          </div>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-4">
          <button class="btn btn-skate" data-action="run-session#start">Start session</button>
          <button class="btn btn-outline-dark" data-action="run-session#finish">End session</button>
          <a class="btn btn-outline-secondary" href="<%= leaderboard_path %>">View leaderboard</a>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-lg-7">
        <div class="card border-0 h-100 card-shadow">
          <div class="card-body p-0">
            <canvas class="w-100 rounded-4" height="320" data-skate-canvas-target="canvas"></canvas>
          </div>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="card border-0 h-100 card-shadow">
          <div class="card-body p-4 d-flex flex-column gap-3">
            <div class="d-flex justify-content-between align-items-center">
              <h5 class="fw-semibold mb-0">Trick input</h5>
              <span class="badge bg-skate-soft text-dark">Keyboard</span>
            </div>
            <div class="d-flex flex-wrap gap-2" data-trick-input-target="keys"></div>
            <div>
              <p class="text-muted small mb-2">Queue</p>
              <ul class="list-unstyled mb-0 d-flex flex-column gap-2" data-run-session-target="queue"></ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-lg-7">
        <div class="card border-0 card-shadow h-100">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <h5 class="fw-semibold mb-0">Tricks catalog</h5>
              <span class="badge bg-light text-dark">Press combos</span>
            </div>
            <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
              <% @tricks.each do |trick| %>
                <li class="queue-item">
                  <div>
                    <div class="fw-semibold"><%= trick.name %></div>
                    <small class="text-muted">Inputs: <%= trick.input_sequence %> • <%= trick.base_coins %> coins • <%= trick.base_xp %> XP</small>
                  </div>
                  <span class="badge bg-light text-dark">Diff <%= trick.difficulty %></span>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="card border-0 card-shadow h-100">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <h5 class="fw-semibold mb-0">Run log</h5>
              <span class="badge bg-light text-dark" data-run-session-target="runTotal">0 coins</span>
            </div>
            <div class="d-flex flex-column gap-2" data-run-session-target="log"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
