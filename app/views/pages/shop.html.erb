<div class="d-flex flex-column gap-4">
  <div class="card border-0 card-shadow">
    <div class="card-body p-4 d-flex flex-wrap justify-content-between align-items-start gap-3">
      <div>
        <p class="eyebrow text-uppercase mb-2">Gear shop</p>
        <h2 class="fw-bold mb-1">Upgrade your stick skater</h2>
        <p class="text-muted mb-0">Pick boards, wheels, bearings, and flair to boost speed, coins, and style multipliers.</p>
      </div>
      <div class="text-end">
        <p class="text-muted small mb-1">Coins available</p>
        <div class="fs-3 fw-bold">3,210</div>
      </div>
    </div>
  </div>

  <div class="row g-3 g-lg-4">
    <% items = [
      { name: "Maple street deck", type: "Deck", price: 950, bonus: "+12% speed" },
      { name: "Carbon fiber deck", type: "Deck", price: 1400, bonus: "+20% speed" },
      { name: "Ceramic bearings", type: "Bearings", price: 780, bonus: "+15% coin gain" },
      { name: "LED wheels", type: "Wheels", price: 620, bonus: "+8% style" },
      { name: "Pro trucks", type: "Trucks", price: 540, bonus: "+6% stability" },
      { name: "Griptape flair", type: "Flair", price: 300, bonus: "+5% combo chance" }
    ] %>

    <% items.each do |item| %>
      <div class="col-md-4">
        <div class="card h-100 border-0 card-shadow">
          <div class="card-body p-4 d-flex flex-column">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="badge bg-skate-soft text-dark"><%= item[:type] %></span>
              <span class="fw-semibold">$<%= item[:price] %></span>
            </div>
            <h5 class="fw-bold mb-2"><%= item[:name] %></h5>
            <p class="text-muted flex-grow-1"><%= item[:bonus] %></p>
            <div class="d-flex gap-2">
              <button class="btn btn-sm btn-dark flex-grow-1" type="button">Equip</button>
              <button class="btn btn-sm btn-outline-secondary" type="button">Details</button>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="card border-0 card-shadow">
    <div class="card-body p-4">
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
          <h5 class="fw-semibold mb-1">Bundle: Speedline</h5>
          <p class="text-muted mb-0">Deck + bearings + wheels for a stacked speed boost.</p>
        </div>
        <div class="d-flex align-items-center gap-3">
          <div class="text-end">
            <small class="text-muted d-block">Price</small>
            <span class="fw-bold">2,200</span>
          </div>
          <a class="btn btn-skate" href="#">Buy bundle</a>
        </div>
      </div>
    </div>
  </div>
</div>
