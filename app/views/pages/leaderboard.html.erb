<div class="d-flex flex-column gap-4">
  <div class="card border-0 card-shadow">
    <div class="card-body p-4 d-flex flex-wrap justify-content-between align-items-start gap-3">
      <div>
        <p class="eyebrow text-uppercase mb-2">Global ranks</p>
        <h2 class="fw-bold mb-1">Leaderboard</h2>
        <p class="text-muted mb-0">Climb with bigger runs, tighter combos, and better idle gear.</p>
      </div>
      <div class="text-end">
        <p class="text-muted small mb-1">Season reset</p>
        <div class="fw-semibold">12d 6h left</div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-8">
      <div class="card border-0 card-shadow">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th scope="col">Rank</th>
                  <th scope="col">Player</th>
                  <th scope="col">Coins</th>
                  <th scope="col">Best combo</th>
                  <th scope="col">Run time</th>
                </tr>
              </thead>
              <tbody>
                <% rows = [
                  { rank: 1, name: "KickflipKid", coins: "142,500", combo: "48x", time: "05:12:40" },
                  { rank: 2, name: "DeckLord", coins: "131,220", combo: "45x", time: "04:55:10" },
                  { rank: 3, name: "ManualMage", coins: "118,040", combo: "41x", time: "04:22:58" },
                  { rank: 4, name: "SwitchSavage", coins: "97,600", combo: "36x", time: "03:18:11" },
                  { rank: 5, name: "Nosegrind", coins: "84,330", combo: "33x", time: "03:02:05" }
                ] %>
                <% rows.each do |row| %>
                  <tr>
                    <th scope="row">
                      <span class="badge bg-dark"><%= row[:rank] %></span>
                    </th>
                    <td class="fw-semibold"><%= row[:name] %></td>
                    <td><%= row[:coins] %></td>
                    <td><%= row[:combo] %></td>
                    <td><%= row[:time] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-4">
      <div class="card border-0 card-shadow h-100">
        <div class="card-body p-4 d-flex flex-column">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="fw-semibold mb-0">Your position</h5>
            <span class="badge bg-skate-soft text-dark">Live</span>
          </div>
          <div class="display-6 fw-bold">#182</div>
          <p class="text-muted">StickSkaterYou • 24,900 coins • 18x combo</p>
          <div class="d-flex gap-2 mb-3">
            <span class="pill"><span class="pill-dot bg-dark"></span> +12 ranks today</span>
            <span class="pill"><span class="pill-dot bg-warning"></span> Run bonus active</span>
          </div>
          <div class="progress-label d-flex justify-content-between mb-1">
            <span>Next milestone</span>
            <span>Top 150</span>
          </div>
          <div class="progress bg-light" role="progressbar" aria-label="Next milestone" aria-valuenow="72" aria-valuemin="0" aria-valuemax="100">
            <div class="progress-bar bg-skate" style="width: 72%"></div>
          </div>
          <a class="btn btn-dark mt-4" href="<%= play_path %>">Push a new run</a>
        </div>
      </div>
    </div>
  </div>
</div>
