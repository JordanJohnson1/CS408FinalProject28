<div class="d-flex flex-column gap-4">
  <div class="card border-0 card-shadow">
    <div class="card-body p-4 d-flex flex-wrap justify-content-between align-items-start gap-3">
      <div>
        <p class="eyebrow text-uppercase mb-2"><%= current_player == @player ? "Your profile" : "Player profile" %></p>
        <div class="d-flex align-items-center gap-3 mb-2">
          <span class="rounded-circle d-inline-block" style="width: 3.5rem; height: 3.5rem; background: <%= @player.avatar_color %>;"></span>
          <div>
            <h2 class="fw-bold mb-1"><%= @player.name %></h2>
            <p class="text-muted mb-0">Coins, combos, and run history for this skater.</p>
          </div>
        </div>
      </div>

      <% if current_player == @player %>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-outline-dark" href="<%= play_path %>">Back to play</a>
          <%= button_to "Reset progress", reset_player_path(@player), method: :patch, class: "btn btn-outline-warning", form: { data: { turbo_confirm: "Reset runs, stats, and upgrades for this player?" } } %>
          <%= button_to "Delete player", player_path(@player), method: :delete, class: "btn btn-outline-danger", form: { data: { turbo_confirm: "Delete this player permanently?" } } %>
        </div>
      <% else %>
        <a class="btn btn-outline-dark" href="<%= leaderboard_path %>">Back to leaderboard</a>
      <% end %>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-md-3">
      <div class="stat-tile">
        <span class="stat-label">Coins</span>
        <span class="stat-value"><%= number_with_delimiter(@player.coins) %></span>
      </div>
    </div>
    <div class="col-md-3">
      <div class="stat-tile">
        <span class="stat-label">XP</span>
        <span class="stat-value"><%= number_with_delimiter(@player.xp) %></span>
      </div>
    </div>
    <div class="col-md-3">
      <div class="stat-tile">
        <span class="stat-label">Best combo</span>
        <span class="stat-value"><%= @player.best_combo %>x</span>
      </div>
    </div>
    <div class="col-md-3">
      <div class="stat-tile">
        <span class="stat-label">Lifetime tricks</span>
        <span class="stat-value"><%= number_with_delimiter(@player.total_tricks) %></span>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-5">
      <div class="card border-0 card-shadow h-100">
        <div class="card-body p-4">
          <h5 class="fw-semibold mb-3">Upgrade loadout</h5>
          <% if @player.purchased_upgrades.any? %>
            <div class="d-flex flex-column gap-2">
              <% @player.purchased_upgrades.each do |upgrade| %>
                <div class="queue-item">
                  <div>
                    <div class="fw-semibold"><%= upgrade[:name] %></div>
                    <small class="text-muted"><%= upgrade[:category] %> • <%= upgrade[:bonus] %></small>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted mb-0">No upgrades owned yet.</p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-7">
      <div class="card border-0 card-shadow h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-semibold mb-0">Recent finished runs</h5>
            <span class="badge bg-light text-dark"><%= @recent_runs.size %> shown</span>
          </div>

          <% if @recent_runs.any? %>
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th scope="col">When</th>
                    <th scope="col">Coins</th>
                    <th scope="col">XP</th>
                    <th scope="col">Duration</th>
                  </tr>
                </thead>
                <tbody>
                  <% @recent_runs.each do |run| %>
                    <tr>
                      <td><%= time_ago_in_words(run.created_at) %> ago</td>
                      <td><%= number_with_delimiter(run.coins_earned) %></td>
                      <td><%= number_with_delimiter(run.xp_earned) %></td>
                      <td><%= run.duration_ms.to_i / 1000 %>s</td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted mb-0">No finished runs recorded yet.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
