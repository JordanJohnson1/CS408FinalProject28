<%= form_with model: @player, url: players_path, local: true do |form| %>
  <div class="mb-3">
    <%= form.label :name, class: "form-label fw-semibold" %>
    <%= form.text_field :name, class: "form-control", placeholder: "Skater name" %>
  </div>
  <div class="mb-3">
    <%= form.label :avatar_color, "Avatar color", class: "form-label fw-semibold" %>
    <%= form.color_field :avatar_color, class: "form-control form-control-color", value: @player.avatar_color || "#0ea5e9" %>
  </div>
  <%= form.submit "Create player", class: "btn btn-skate w-100" %>
<% end %>
