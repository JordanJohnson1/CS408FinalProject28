<div class="d-flex flex-column gap-4">
  <div class="card border-0 card-shadow">
    <div class="card-body p-4 d-flex flex-wrap justify-content-between align-items-start gap-3">
      <div>
        <p class="eyebrow text-uppercase mb-2">Global ranks</p>
        <h2 class="fw-bold mb-1">Leaderboard</h2>
        <p class="text-muted mb-0">Climb with bigger runs, tighter combos, and better idle gear.</p>
      </div>
      <div class="text-end">
        <p class="text-muted small mb-1">Season reset</p>
        <div class="fw-semibold">12d 6h left</div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-8">
      <div class="card border-0 card-shadow">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th scope="col">Rank</th>
                  <th scope="col">Player</th>
                  <th scope="col">Coins</th>
                  <th scope="col">Best combo</th>
                  <th scope="col">Lifetime tricks</th>
                </tr>
              </thead>
              <tbody>
                <% @top_players.each_with_index do |player, idx| %>
                  <tr>
                    <th scope="row">
                      <span class="badge bg-dark"><%= idx + 1 %></span>
                    </th>
                    <td class="fw-semibold"><%= player.name %></td>
                    <td><%= number_with_delimiter(player.coins) %></td>
                    <td><%= player.best_combo %>x</td>
                    <td><%= player.total_tricks %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-4">
      <div class="card border-0 card-shadow h-100">
        <div class="card-body p-4 d-flex flex-column">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="fw-semibold mb-0">Your position</h5>
            <span class="badge bg-skate-soft text-dark">Live</span>
          </div>
          <% if current_player %>
            <div class="display-6 fw-bold">You</div>
            <p class="text-muted mb-2"><%= current_player.name %> • <%= number_with_delimiter(current_player.coins) %> coins • <%= current_player.best_combo %>x combo</p>
            <div class="d-flex gap-2 mb-3">
              <span class="pill"><span class="pill-dot bg-dark"></span> <%= current_player.total_tricks %> tricks</span>
              <span class="pill"><span class="pill-dot bg-warning"></span> <%= current_player.total_coins_earned %> coins earned</span>
            </div>
          <% else %>
            <p class="text-muted">Create a player to see your live stats.</p>
          <% end %>
          <a class="btn btn-dark mt-3" href="<%= play_path %>">Push a new run</a>
        </div>
      </div>
    </div>
  </div>
</div>
